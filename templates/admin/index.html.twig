{% extends 'base.html.twig' %}

{% block title %}Admin - Avella{% endblock %}

{% block body %}
    <div class="min-h-screen bg-slate-50 text-slate-900">
        <aside class="fixed inset-y-0 left-0 hidden w-64 border-r border-slate-200 bg-white px-5 py-6 md:block">
            <a href="{{ path('app_admin') }}" class="font-serif text-2xl font-bold text-slate-900">Avella Admin</a>

            <nav class="mt-8 space-y-1 text-sm font-medium">
                <a href="{{ path('app_admin') }}" class="block rounded-md bg-slate-900 px-3 py-2 text-white">Dashboard</a>
                <a href="#" class="block rounded-md px-3 py-2 text-slate-600 hover:bg-slate-100">Users</a>
                <a href="#" class="block rounded-md px-3 py-2 text-slate-600 hover:bg-slate-100">Categories</a>
                <a href="#" class="block rounded-md px-3 py-2 text-slate-600 hover:bg-slate-100">Boutiques</a>
                <a href="#" class="block rounded-md px-3 py-2 text-slate-600 hover:bg-slate-100">Products</a>
                <a href="#" class="block rounded-md px-3 py-2 text-slate-600 hover:bg-slate-100">Orders</a>
            </nav>
        </aside>

        <main class="md:pl-64">
            <header class="border-b border-slate-200 bg-white px-6 py-4">
                <div class="flex items-center justify-between gap-4">
                    <div>
                        <h1 class="text-2xl font-bold">Dashboard</h1>
                        <p class="text-sm text-slate-500">Marketplace overview</p>
                    </div>

                    <a href="{{ path('app_logout') }}" class="rounded-md border border-slate-200 px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100">
                        Logout
                    </a>
                </div>
            </header>

            <section class="px-6 py-6">
                <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
                    <article class="rounded-md border border-slate-200 bg-white p-5">
                        <p class="text-sm font-medium text-slate-500">Users</p>
                        <p class="mt-2 text-3xl font-bold">{{ stats.users }}</p>
                    </article>
                    <article class="rounded-md border border-slate-200 bg-white p-5">
                        <p class="text-sm font-medium text-slate-500">Boutiques</p>
                        <p class="mt-2 text-3xl font-bold">{{ stats.boutiques }}</p>
                    </article>
                    <article class="rounded-md border border-slate-200 bg-white p-5">
                        <p class="text-sm font-medium text-slate-500">Products</p>
                        <p class="mt-2 text-3xl font-bold">{{ stats.products }}</p>
                    </article>
                    <article class="rounded-md border border-slate-200 bg-white p-5">
                        <p class="text-sm font-medium text-slate-500">Orders</p>
                        <p class="mt-2 text-3xl font-bold">{{ stats.orders }}</p>
                    </article>
                </div>

                <div class="mt-4 grid gap-4 sm:grid-cols-3">
                    <article class="rounded-md border border-slate-200 bg-white p-5">
                        <p class="text-sm font-medium text-slate-500">Categories</p>
                        <p class="mt-2 text-2xl font-bold">{{ stats.categories }}</p>
                    </article>
                    <article class="rounded-md border border-slate-200 bg-white p-5">
                        <p class="text-sm font-medium text-slate-500">Pending carts</p>
                        <p class="mt-2 text-2xl font-bold">{{ stats.pendingOrders }}</p>
                    </article>
                    <article class="rounded-md border border-slate-200 bg-white p-5">
                        <p class="text-sm font-medium text-slate-500">Confirmed orders</p>
                        <p class="mt-2 text-2xl font-bold">{{ stats.confirmedOrders }}</p>
                    </article>
                </div>

                <section class="mt-6 rounded-md border border-slate-200 bg-white">
                    <div class="border-b border-slate-200 px-5 py-4">
                        <h2 class="font-bold">Recent orders</h2>
                    </div>

                    {% if recentOrders is empty %}
                        <p class="px-5 py-8 text-sm text-slate-500">No orders yet.</p>
                    {% else %}
                        <div class="overflow-x-auto">
                            <table class="w-full text-left text-sm">
                                <thead class="bg-slate-50 text-slate-500">
                                    <tr>
                                        <th class="px-5 py-3">ID</th>
                                        <th class="px-5 py-3">Buyer</th>
                                        <th class="px-5 py-3">Status</th>
                                        <th class="px-5 py-3">Date</th>
                                        <th class="px-5 py-3 text-right">Total</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for order in recentOrders %}
                                        <tr class="border-t border-slate-100">
                                            <td class="px-5 py-3">#{{ order.id }}</td>
                                            <td class="px-5 py-3">
                                                {% if order.user %}
                                                    {{ order.user.prenom }} {{ order.user.nom }}
                                                {% else %}
                                                    -
                                                {% endif %}
                                            </td>
                                            <td class="px-5 py-3">{{ order.statut }}</td>
                                            <td class="px-5 py-3">{{ order.createdAt ? order.createdAt|date('Y-m-d H:i') : '-' }}</td>
                                            <td class="px-5 py-3 text-right font-semibold">{{ order.total }} TND</td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% endif %}
                </section>
            </section>
        </main>
    </div>
{% endblock %}
