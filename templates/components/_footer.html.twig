{# templates/components/_footer.html.twig
   Simple page footer — included only on buyer-dashboard.html.twig
   (mirrors the footer present in the original buyer-dashboard.php).
#}
<footer class="bg-white border-t border-gray-100 mt-16">
    <div class="max-w-7xl mx-auto px-6 py-10">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-sm text-gray-500">

            {# Brand #}
            <div class="space-y-2">
                <h3 class="text-lg font-bold text-indigo-600">Avella</h3>
                <p>La marketplace qui connecte les acheteurs et les vendeurs locaux.</p>
            </div>

            {# Navigation #}
            <div class="space-y-2">
                <h4 class="font-semibold text-gray-700">Navigation</h4>
                <ul class="space-y-1">
                    <li><a href="{{ path('buyer_dashboard') }}" class="hover:text-indigo-600 transition-colors">Accueil</a></li>
                    <li><a href="{{ path('produit_index') }}" class="hover:text-indigo-600 transition-colors">Produits</a></li>
                </ul>
            </div>

            {# Account #}
            <div class="space-y-2">
                <h4 class="font-semibold text-gray-700">Mon compte</h4>
                <ul class="space-y-1">
                    {% if app.user %}
                        <li>
                            <span class="text-gray-600">{{ app.user.prenom }} {{ app.user.nom }}</span>
                        </li>
                        <li>
                            <a href="{{ path('app_logout') }}" class="hover:text-red-500 transition-colors">Déconnexion</a>
                        </li>
                    {% else %}
                        <li><a href="{{ path('app_login') }}" class="hover:text-indigo-600 transition-colors">Connexion</a></li>
                    {% endif %}
                </ul>
            </div>

        </div>

        <div class="mt-8 pt-6 border-t border-gray-100 text-center text-xs text-gray-400">
            &copy; {{ "now"|date("Y") }} Avella. Tous droits réservés.
        </div>
    </div>
</footer>
