{% if items|length == 0 %}
    <div class="flex min-h-56 flex-col items-center justify-center space-y-3 rounded-2xl border border-dashed border-[#d8bca7] bg-white/35 px-6 text-center text-[#8a6652]">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-[#c9a989]" fill="none"
             viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                  d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2 9m5-9v9m4-9v9"/>
        </svg>
        <p class="font-serif text-lg font-semibold text-[#4f3222]">Votre panier est vide.</p>
        <a href="{{ path('produit_index') }}"
           class="rounded-full bg-[#755440] px-4 py-2 text-sm font-semibold text-white transition hover:bg-[#4f3222]">
            Decouvrir les produits
        </a>
    </div>
{% else %}
    <style>
        .avella-cart-list {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }

        .avella-cart-item {
            display: grid;
            grid-template-columns: 72px minmax(0, 1fr);
            gap: 0.85rem;
            align-items: start;
            border: 1px solid #e2c9b8;
            border-radius: 1rem;
            background: rgba(255, 255, 255, 0.58);
            padding: 0.8rem;
            box-shadow: 0 10px 24px rgba(79, 50, 34, 0.07);
        }

        .avella-cart-thumb {
            width: 72px;
            height: 88px;
            border-radius: 0.8rem;
            overflow: hidden;
            background: #f4e5d9;
        }

        .avella-cart-thumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

        .avella-cart-main {
            min-width: 0;
            display: grid;
            gap: 0.65rem;
        }

        .avella-cart-top {
            display: flex;
            justify-content: space-between;
            gap: 0.75rem;
            align-items: start;
        }

        .avella-cart-name {
            color: #4f3222;
            font-weight: 700;
            line-height: 1.2;
            margin: 0;
        }

        .avella-cart-shop {
            color: #8b674f;
            font-size: 0.8rem;
            margin-top: 0.15rem;
        }

        .avella-cart-unit {
            color: #755440;
            font-size: 0.78rem;
            font-weight: 700;
            margin-top: 0.25rem;
        }

        .avella-cart-bottom {
            display: flex;
            justify-content: space-between;
            gap: 0.75rem;
            align-items: end;
        }

        .avella-cart-stepper {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            border: 1px solid #dbc1ae;
            border-radius: 999px;
            background: #fffaf6;
            padding: 0.2rem;
        }

        .avella-qty-btn {
            width: 1.65rem;
            height: 1.65rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border: 0;
            border-radius: 999px;
            background: #f4e5d9;
            color: #4f3222;
            font-weight: 800;
            line-height: 1;
            transition: background 0.15s ease, transform 0.15s ease;
        }

        .avella-qty-btn:hover {
            background: #e2c9b8;
            transform: translateY(-1px);
        }

        .avella-qty-val {
            min-width: 1.35rem;
            text-align: center;
            color: #4f3222;
            font-weight: 800;
            font-size: 0.9rem;
        }

        .avella-cart-pricebox {
            text-align: right;
            white-space: nowrap;
        }

        .avella-cart-item-sub {
            display: block;
            color: #4f3222;
            font-weight: 800;
            font-size: 0.95rem;
        }

        .avella-cart-remove {
            margin-top: 0.2rem;
            color: #c2413a;
            font-size: 0.78rem;
            font-weight: 700;
            transition: color 0.15s ease;
        }

        .avella-cart-remove:hover {
            color: #8f211c;
        }
    </style>

    <div class="space-y-3" id="cart-items-list">
        {% for cp in items %}
            {% set produit = cp.produit %}
            <div class="cart-item-row avella-cart-item" data-item-id="{{ cp.id }}">
                <div class="avella-cart-thumb">
                    {% if produit.image %}
                        <img src="{{ asset(produit.image) }}"
                             alt="{{ produit.nom }}"
                             onerror="this.closest('.avella-cart-thumb').innerHTML='<div class=&quot;flex h-full w-full items-center justify-center text-xs font-bold text-[#c9a989]&quot;>AV</div>'">
                    {% else %}
                        <div class="flex h-full w-full items-center justify-center text-xs text-[#c9a989]">
                            N/A
                        </div>
                    {% endif %}
                </div>

                <div class="avella-cart-main">
                    <div class="avella-cart-top">
                        <div class="min-w-0">
                            <p class="avella-cart-name truncate">{{ produit.nom }}</p>
                            <p class="avella-cart-shop truncate">{{ produit.boutique ? produit.boutique.nom }}</p>
                            <p class="avella-cart-unit">{{ produit.prix|number_format(2, ',', ' ') }} TND</p>
                        </div>
                        <div class="avella-cart-pricebox">
                            <span class="avella-cart-item-sub">
                                {{ (produit.prix * cp.quantite)|number_format(2, '.', '') }} TND
                            </span>
                            <button type="button"
                                    class="remove-item avella-cart-remove"
                                    data-item-id="{{ cp.id }}"
                                    data-cp-id="{{ cp.id }}"
                                    aria-label="Supprimer l'article">
                                Retirer
                            </button>
                        </div>
                    </div>
                    <div class="avella-cart-bottom">
                        <div class="avella-cart-stepper">
                            <button type="button"
                                    class="qty-btn qty-minus avella-qty-btn"
                                    data-item-id="{{ cp.id }}"
                                    data-cp-id="{{ cp.id }}"
                                    data-action="minus"
                                    aria-label="Diminuer la quantite">-</button>
                            <span class="qty-value avella-qty-val">{{ cp.quantite }}</span>
                            <button type="button"
                                    class="qty-btn qty-plus avella-qty-btn"
                                    data-item-id="{{ cp.id }}"
                                    data-cp-id="{{ cp.id }}"
                                    data-action="plus"
                                    aria-label="Augmenter la quantite">+</button>
                        </div>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>

    <div id="cart-fragment-total"
         data-total="{{ total|number_format(2, '.', '') }}"
         class="mt-4 flex items-center justify-between border-t border-[#d8bca7] pt-4 text-sm font-bold text-[#4f3222]">
        <span>Total</span>
        <span>{{ total|number_format(2, ',', ' ') }} TND</span>
    </div>
{% endif %}
