{# templates/components/_cart_fragment.html.twig
   Renders only the cart body: empty state OR items list.
   Fetched by cart.js via GET /buyer/cart (cart_fragment route).

   Expected variables:
     items  (CommandeProduits[])  — line items
     total  (float)               — cart total
#}

{% if items|length == 0 %}

    {# ── Empty state ── #}
    <div class="flex flex-col items-center justify-center h-48 text-center text-gray-400 space-y-3">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-gray-200" fill="none"
             viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                  d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2 9m5-9v9m4-9v9m1-10V4a1 1
                     0 00-1-1h-4a1 1 0 00-1 1v3"/>
        </svg>
        <p class="text-sm">Votre panier est vide.</p>
        <a href="{{ path('produit_index') }}"
           class="text-indigo-600 text-sm font-medium hover:underline">
            Découvrir les produits →
        </a>
    </div>

{% else %}

    {# ── Item list ── #}
    <div class="space-y-0" id="cart-items-list">
        {% for cp in items %}
            {% set produit = cp.produit %}
            <div class="cart-item-row" data-item-id="{{ cp.id }}">

                {# Thumbnail #}
                <div class="h-14 w-14 rounded-lg overflow-hidden bg-gray-100 flex-shrink-0">
                    {% if produit.image %}
                        <img src="{{ asset('images/' ~ produit.image) }}"
                             alt="{{ produit.nom }}"
                             class="h-full w-full object-cover">
                    {% else %}
                        <div class="h-full w-full flex items-center justify-center text-gray-300 text-xs">
                            N/A
                        </div>
                    {% endif %}
                </div>

                {# Info + quantity controls #}
                <div class="min-w-0">
                    <p class="text-sm font-medium text-gray-800 truncate">{{ produit.nom }}</p>
                    <p class="text-xs text-gray-400 truncate">{{ produit.boutique ? produit.boutique.nom }}</p>
                    <p class="text-xs text-indigo-600 font-semibold mt-0.5">
                        {{ produit.prix|number_format(2, ',', ' ') }} DT
                    </p>
                    {# Quantity stepper — wired in cart.js via data-item-id on the parent row #}
                    <div class="flex items-center gap-2 mt-1">
                        <button class="qty-btn qty-minus" data-item-id="{{ cp.id }}" aria-label="Diminuer">−</button>
                        <span class="qty-value text-sm font-medium w-5 text-center">{{ cp.quantite }}</span>
                        <button class="qty-btn qty-plus"  data-item-id="{{ cp.id }}" aria-label="Augmenter">+</button>
                    </div>
                </div>

                {# Line total + remove #}
                <div class="text-right flex flex-col items-end gap-1 flex-shrink-0">
                <span class="text-sm font-semibold text-gray-800">
                    {{ (produit.prix * cp.quantite)|number_format(2, ',', ' ') }} DT
                </span>
                    <button class="remove-item text-xs text-red-400 hover:text-red-600 transition-colors"
                            data-item-id="{{ cp.id }}"
                            aria-label="Supprimer l'article">
                        Retirer
                    </button>
                </div>

            </div>
        {% endfor %}
    </div>

    {# Total row (re-rendered on each refresh) #}
    <div class="mt-4 pt-4 border-t border-gray-100 flex items-center justify-between text-sm font-bold text-gray-800">
        <span>Total</span>
        <span>{{ total|number_format(2, ',', ' ') }} DT</span>
    </div>

{% endif %}
