{# templates/components/_sidebar.html.twig
   Off-canvas sidebar (mobile navigation).
   Controlled by buyer-dashboard.js: openSidebar() / closeSidebar()
   Expected variables:
     categories  (Categorie[])  — list of all categories
#}

{# Full-screen overlay #}
<div id="sidebar-wrapper"
     class="fixed inset-0 z-40 bg-black/50 opacity-0 pointer-events-none transition-opacity duration-300">
</div>

{# Sidebar panel #}
<aside id="sidebar"
       aria-hidden="true"
       class="fixed top-0 left-0 z-50 h-full w-72 bg-white shadow-xl
              -translate-x-full transition-transform duration-300 ease-in-out
              flex flex-col">

    {# Header #}
    <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100">
        <span class="text-lg font-bold text-indigo-600">Menu</span>
        <button id="close-sidebar"
                class="p-1 text-gray-500 hover:text-gray-800 transition-colors"
                aria-label="Fermer le menu">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
        </button>
    </div>

    {# Navigation links #}
    <nav class="flex-1 overflow-y-auto px-5 py-4 space-y-1">
        <a href="{{ path('buyer_dashboard') }}"
           class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium text-gray-700
                  hover:bg-indigo-50 hover:text-indigo-600 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
            </svg>
            Accueil
        </a>

        <a href="{{ path('produit_index') }}"
           class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium text-gray-700
                  hover:bg-indigo-50 hover:text-indigo-600 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
            </svg>
            Tous les produits
        </a>

        {# Categories #}
        {% if categories is defined and categories|length > 0 %}
            <div class="pt-4 pb-1">
                <p class="px-3 text-xs font-semibold text-gray-400 uppercase tracking-wide">Catégories</p>
            </div>
            {% for categorie in categories %}
                <a href="{{ path('produit_index', { categorie: categorie.nom }) }}"
                   class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm text-gray-700
                  hover:bg-indigo-50 hover:text-indigo-600 transition-colors">
                    {% if categorie.photo %}
                        <img src="{{ asset('images/' ~ categorie.photo) }}"
                             alt="{{ categorie.nom }}"
                             class="h-5 w-5 rounded-full object-cover">
                    {% else %}
                        <span class="h-5 w-5 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-600 text-xs font-bold">
                {{ categorie.nom|slice(0,1)|upper }}
            </span>
                    {% endif %}
                    {{ categorie.nom }}
                </a>
            {% endfor %}
        {% endif %}
    </nav>

    {# Footer — logout #}
    {% if app.user %}
        <div class="border-t border-gray-100 px-5 py-4">
            <a href="{{ path('app_logout') }}"
               class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium text-red-600
                  hover:bg-red-50 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                </svg>
                Déconnexion
            </a>
        </div>
    {% endif %}

</aside>

{# Overlay click-to-close — wired in buyer-dashboard.js #}
<div id="sidebar-overlay" class="fixed inset-0 z-39 hidden"></div>
