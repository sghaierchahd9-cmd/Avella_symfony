{# templates/boutique/listeBoutiques.html.twig #}

{% extends 'base.html.twig' %}

{% block title %}Avella — Boutiques{% endblock %}

{% block body %}
    <body class="overflow-y-scroll overflow-x-hidden scroll-smooth bg-[#f4e5d9] min-h-300">

    {# ── NAVBAR ──────────────────────────────────────────────── #}
    <header class="sticky top-0 isolate z-50 border-b border-black/10 bg-[#c99f85]/95 backdrop-blur-md">
        <div class="mx-auto flex w-full max-w-[1400px] items-center gap-2 px-3 py-3 sm:px-4">

            <button id="open-sidebar" aria-label="Open sidebar"
                    class="rounded-full p-2 text-[#4f3222] transition hover:bg-[#755440] hover:text-[#fff8f3] active:scale-95">
                {# icône hamburger #}
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/>
                </svg>
            </button>

            <div class="flex shrink-0 items-center gap-3">
                <a href="{{ path('app_buyer_dashboard') }}">
                    <img src="{{ asset('images/AHHH.png') }}" alt="Avella" class="h-10 sm:h-11"/>
                </a>
                <div class="hidden items-center gap-1 md:flex">
                    <a href="{{ path('app_buyer_dashboard') }}"
                       class="rounded-full px-4 py-2 text-sm font-medium tracking-wide text-avella5 transition hover:bg-white/30">Home</a>
                    <a href="{{ path('app_produits') }}"
                       class="rounded-full px-4 py-2 text-sm font-medium tracking-wide text-avella5 transition hover:bg-white/30">Explore</a>
                    <a href="{{ path('app_boutique') }}"
                       class="rounded-full px-4 py-2 text-sm font-medium tracking-wide text-avella5 transition hover:bg-white/30">Boutiques</a>
                    {% if app.user and app.user.role == 'vendeur' %}
                        <a href="{{ path('app_seller_dashboard') }}"
                           class="rounded-full px-4 py-2 text-sm font-medium tracking-wide text-avella5 transition hover:bg-white/30">Mon Dashboard</a>
                    {% endif %}
                </div>
            </div>

            {# barre de recherche #}
            <form action="{{ path('app_produits') }}" method="GET"
                  class="relative z-10 mx-auto hidden max-w-xl flex-1 md:flex">
            <span class="absolute inset-y-0 left-3 flex items-center text-[#5D4133]">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24"
                     stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M21 21l-4.35-4.35m0 0A7.5 7.5 0 1110.5 3a7.5 7.5 0 016.15 13.65z"/>
                </svg>
            </span>
                <input type="text" name="nom" placeholder="Rechercher..."
                       class="w-full rounded-full border border-[#7f5e49] bg-[#e3d5cc] px-10 py-2 font-light placeholder-[#5D4133] transition focus:border-avella3 focus:outline-none focus:ring-2 focus:ring-avella3">
            </form>

            <div class="ml-auto flex items-center gap-1.5 sm:gap-2">
                {# panier #}
                <button id="cart-open-btn" aria-label="Cart" class="rounded-full p-1.5 transition hover:bg-white/30 relative">
                    <svg xmlns="http://www.w3.org/2000/svg" width="35px" height="35px" viewBox="0 0 21 21">
                        <g fill="none" fill-rule="evenodd" transform="translate(2 4)">
                            <path d="m3 2.5h12.5l-1.5855549 5.54944226..." stroke="#000000" stroke-linecap="round" stroke-linejoin="round"/>
                            <g fill="#000000"><circle cx="5" cy="12" r="1"/><circle cx="13" cy="12" r="1"/></g>
                        </g>
                    </svg>
                </button>

                {% if app.user %}
                    <a href="{{ path('app_mon_compte') }}" class="btn-primary ml-1 text-sm">Mon compte</a>
                    <a href="{{ path('app_logout') }}" class="btn-primary ml-1 text-sm">Déconnexion</a>
                {% else %}
                    <a href="{{ path('app_login') }}" class="btn-primary ml-1">Login</a>
                {% endif %}
            </div>
        </div>
    </header>

    {# ── TITRE ───────────────────────────────────────────────── #}
    <h1 class="font-serif text-4xl md:text-5xl text-center mb-16 text-[#603f2a]">
        Découvrez nos boutiques
    </h1>

    {# ── CATÉGORIES (pills) ──────────────────────────────────── #}
    <section class="px-6 mb-16">
        <h2 class="ml-4 font-serif text-2xl mb-8 text-[#6b5447]">Nos catégories</h2>
        <div class="flex gap-12 justify-center flex-wrap" id="categories-container">

            {% for cat in categories %}
                <button class="flex flex-col items-center group cursor-pointer cat-item"
                        data-cat-id="{{ cat.id }}">

                    <div class="w-28 h-28 rounded-full border-4 border-orange-200 bg-white
                        flex items-center justify-center mb-2
                        group-hover:bg-orange-50 transition-colors overflow-hidden cat-circle">
                        {% if cat.photo %}
                            <img src="{{ asset(cat.photo) }}"
                                 alt="{{ cat.nom }}"
                                 class="w-12 h-12 object-cover">
                        {% else %}
                            <span class="text-2xl">🏷️</span>
                        {% endif %}
                    </div>

                    <span class="text-[#6b5447] font-medium text-sm text-center">
                {{ cat.nom }}
            </span>
                </button>
            {% endfor %}

        </div>
    </section>

    {# ── BARRE DE RECHERCHE ──────────────────────────────────── #}
    <section class="flex justify-center mb-16 px-6">
        <div class="w-full max-w-md">
            <div class="flex items-center bg-white border-3 border-orange-200 rounded-full px-4 py-3 shadow-sm">
                <svg class="w-5 h-5 text-stone-600 mr-3 shrink-0" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M21 21l-4.35-4.35m0 0A7.5 7.5 0 1110.5 3a7.5 7.5 0 016.15 13.65z"/>
                </svg>
                <input type="text" id="search-input" placeholder="Recherchez une boutique par nom..."
                       autocomplete="off"
                       class="w-full bg-transparent outline-none text-[#6b5447] placeholder-stone-600"/>
            </div>
        </div>
    </section>

    {# ── LISTE DES BOUTIQUES (injectée par JS) ───────────────── #}
    <section class="px-6 pb-20">
        <h2 id="section-title" class="ml-4 font-serif text-2xl mb-6 text-[#6b5447]">
            Toutes nos boutiques
        </h2>
        <div id="boutiques-list" class="flex flex-wrap ml-4 gap-8"></div>
        <div id="empty-state" class="hidden text-center py-20">
            <p class="text-[#8B674F] text-lg">Aucune boutique trouvée.</p>
            <button id="reset-btn" class="inline-block mt-4 text-sm text-[#6b5447] hover:underline cursor-pointer">
                Voir toutes les boutiques →
            </button>
        </div>
    </section>

    {# ── SIDEBAR ─────────────────────────────────────────────── #}
    <div id="sidebar-wrapper" class="pointer-events-none fixed inset-0 z-[70] opacity-0 transition-opacity duration-300">
        <div id="sidebar-overlay" class="absolute inset-0 bg-black/45"></div>
        <aside id="sidebar" aria-hidden="true"
               class="absolute left-0 top-0 flex h-full w-[22rem] max-w-[88vw] -translate-x-full flex-col
                  overflow-y-auto border-r border-[#a88066] bg-avella2
                  shadow-[0_18px_46px_rgba(77,48,31,0.28)] transition-transform duration-300 ease-out">
            <div class="relative border-b border-[#b08a72] px-6 py-5">
                <div class="absolute right-5 top-5">
                    <button id="close-sidebar" class="rounded-full p-2 text-[#5b3d2a] transition hover:bg-white/40">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                             stroke-width="1.8" stroke="currentColor" class="h-6 w-6">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/>
                        </svg>
                    </button>
                </div>
                <div class="pr-12">
                    <p class="text-xs uppercase tracking-[0.22em] text-avella3">Maison Avella</p>
                    <h2 class="mt-2 font-serif text-4xl text-[#4f3222]">Avella</h2>
                    <p class="mt-2 text-sm text-[#6d4d3b]">Elegance artisanale pour votre quotidien.</p>
                </div>
            </div>
            <div class="px-5 py-6">
                <nav class="space-y-2">
                    <a href="{{ path('app_buyer_dashboard') }}"
                       class="group flex items-center justify-between rounded-2xl border border-[#c7a88f]
                          bg-white/45 px-4 py-3 text-[#5a3a29] transition hover:border-[#9a7158] hover:bg-white/70">
                        <span class="font-medium">Accueil</span>
                    </a>
                    <a href="{{ path('app_boutique') }}"
                       class="group flex items-center justify-between rounded-2xl border border-[#c7a88f]
                          bg-white/45 px-4 py-3 text-[#5a3a29] transition hover:border-[#9a7158] hover:bg-white/70">
                        <span class="font-medium">Boutiques</span>
                    </a>
                    <a href="{{ path('app_produits') }}"
                       class="group flex items-center justify-between rounded-2xl border border-[#c7a88f]
                          bg-white/45 px-4 py-3 text-[#5a3a29] transition hover:border-[#9a7158] hover:bg-white/70">
                        <span class="font-medium">Explore</span>
                    </a>
                </nav>
            </div>
        </aside>
    </div>

    {# ── JAVASCRIPT ──────────────────────────────────────────── #}
    {#
    CHANGEMENT CLÉ par rapport au PHP natif :
    L'URL du fetch ne pointe plus vers search_boutiques.php
    mais vers la route Symfony générée par path()
    On passe l'URL via un data-attribute pour éviter de mélanger Twig et JS
    #}
    <div id="js-config"
         data-search-url="{{ path('app_boutique_search') }}"
         style="display:none"></div>

    <script>
        (function () {
            'use strict';

            // ── récupérer l'URL générée par Symfony ──────────────────
            const SEARCH_URL = document.getElementById('js-config').dataset.searchUrl;

            const searchInput   = document.getElementById('search-input');
            const boutiquesList = document.getElementById('boutiques-list');
            const emptyState    = document.getElementById('empty-state');
            const sectionTitle  = document.getElementById('section-title');
            const resetBtn      = document.getElementById('reset-btn');
            const catItems      = document.querySelectorAll('.cat-item');

            let currentCatId  = 0;
            let currentSearch = '';
            let debounceTimer = null;
            const DEBOUNCE_MS = 300;

            // ── construction de la card ───────────────────────────────
            function buildCard(b) {
                const photoHtml = b.photo
                    ? `<img src="${esc(b.photo)}" alt="${esc(b.nom)}" class="object-cover h-full w-full rounded-full">`
                    : `<span class="text-3xl">🏪</span>`;

                let desc = b.description || '';
                const dots = desc.length > 100 ? '...' : '';
                desc = esc(desc.substring(0, 100)) + dots;

                const catBadge = b.categorie_nom
                    ? `<span class="block text-center text-[#C99F85] text-xs mb-3">${esc(b.categorie_nom)}</span>`
                    : '';

                // NOTE : l'URL du profil boutique sera à adapter quand tu créeras BoutiqueController::profil()
                return `
        <div class="items-center bg-white h-100 w-70 justify-center rounded-2xl shadow-md p-6">
            <div class="w-28 h-28 rounded-full border-3 border-orange-200 flex items-center
                        justify-center mb-3 bg-white mx-auto overflow-hidden">
                ${photoHtml}
            </div>
            <span class="block text-center text-[#6b5447] font-medium text-xl mb-1">
                ${esc(b.nom)}
            </span>
            ${catBadge}
            <p class="text-[#99877c] font-medium text-sm text-center">${desc}</p>
            <a href="/boutique/${parseInt(b.id)}"
               class="block text-center bg-[#6b5447] rounded-full w-40 h-10
                      leading-10 mx-auto mt-6 text-white text-sm hover:bg-[#5a4438] transition">
                Découvrir
            </a>
        </div>`;
            }

            function esc(str) {
                const d = document.createElement('div');
                d.textContent = String(str);
                return d.innerHTML;
            }

            function renderBoutiques(boutiques) {
                boutiquesList.innerHTML = '';
                emptyState.classList.add('hidden');

                if (boutiques.length === 0) {
                    emptyState.classList.remove('hidden');
                    sectionTitle.textContent = 'Aucun résultat';
                    return;
                }

                boutiques.forEach(b => boutiquesList.insertAdjacentHTML('beforeend', buildCard(b)));

                if (currentSearch !== '' && currentCatId > 0) {
                    sectionTitle.textContent = 'Résultats filtrés';
                } else if (currentSearch !== '') {
                    sectionTitle.textContent = `Résultats pour "${currentSearch}"`;
                } else if (currentCatId > 0) {
                    sectionTitle.textContent = 'Boutiques dans cette catégorie';
                } else {
                    sectionTitle.textContent = 'Toutes nos boutiques';
                }
            }

            // ── appel AJAX ────────────────────────────────────────────
            function fetchBoutiques() {
                const params = new URLSearchParams({
                    search:       currentSearch,
                    categorie_id: currentCatId,
                });

                fetch(`${SEARCH_URL}?${params.toString()}`)
                    .then(res => res.json())
                    .then(data => { if (data.success) renderBoutiques(data.boutiques); })
                    .catch(err => console.error('Fetch échoué:', err));
            }

            // ── live search ───────────────────────────────────────────
            searchInput.addEventListener('input', function () {
                currentSearch = this.value.trim();
                clearTimeout(debounceTimer);
                debounceTimer = setTimeout(fetchBoutiques, DEBOUNCE_MS);
            });

            // ── filtre catégorie ──────────────────────────────────────
            catItems.forEach(btn => {
                btn.addEventListener('click', function () {
                    const catId = parseInt(this.dataset.catId);
                    if (currentCatId === catId) {
                        currentCatId = 0;
                        resetCatStyles();
                    } else {
                        currentCatId = catId;
                        setCatActive(this);
                    }
                    fetchBoutiques();
                });
            });

            function setCatActive(activeBtn) {
                catItems.forEach(btn => {
                    const circle = btn.querySelector('.cat-circle');
                    circle.classList.remove('border-[#6b5447]', 'bg-orange-50');
                    circle.classList.add('border-orange-200', 'bg-white');
                });
                const circle = activeBtn.querySelector('.cat-circle');
                circle.classList.remove('border-orange-200', 'bg-white');
                circle.classList.add('border-[#6b5447]', 'bg-orange-50');
            }

            function resetCatStyles() {
                catItems.forEach(btn => {
                    const circle = btn.querySelector('.cat-circle');
                    circle.classList.remove('border-[#6b5447]', 'bg-orange-50');
                    circle.classList.add('border-orange-200', 'bg-white');
                });
            }

            resetBtn.addEventListener('click', function () {
                currentCatId = 0;
                currentSearch = '';
                searchInput.value = '';
                resetCatStyles();
                fetchBoutiques();
            });

            // ── auto-select depuis l'URL (?categorie=Vêtements) ───────
            const urlParams      = new URLSearchParams(window.location.search);
            const categorieNom   = urlParams.get('categorie');
            if (categorieNom) {
                catItems.forEach(btn => {
                    const label = btn.querySelector('span');
                    if (label && label.textContent.trim().toLowerCase() === categorieNom.toLowerCase()) {
                        currentCatId = parseInt(btn.dataset.catId);
                        setCatActive(btn);
                    }
                });
            }

            // ── chargement initial ────────────────────────────────────
            fetchBoutiques();

        })();
    </script>

    <script src="{{ asset('js/script.js') }}" defer></script>

    </body>
{% endblock %}