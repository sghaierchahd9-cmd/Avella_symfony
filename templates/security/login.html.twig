{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}
<body class="bg-[#C99F85]">
<div class="min-h-screen flex justify-center items-center bg-[#C99F85]">
  <div class="bg-white w-full max-w-md rounded-xl shadow-lg p-9 flex flex-col gap-4">

    <h1 class="text-center text-4xl text-[#5c3202] font-light font-serif mb-4">
      Connecter à votre compte
    </h1>

    {% if error %}
      <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded">
        {{ error.messageKey|trans(error.messageData, 'security') }}
      </div>
    {% endif %}

    {% if app.user %}
      <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded">
        Vous êtes connecté en tant que {{ app.user.userIdentifier }},
        <a href="{{ logout_path() }}" class="underline">Se déconnecter</a>
      </div>
    {% endif %}

    <form method="post">
      <div class="flex flex-col gap-4">

        <div>
          <label class="block text-xl text-[#5c3202] font-serif font-light mb-1">
            Adresse Email
          </label>
          <input type="email" value="{{ last_username }}" name="email" id="username"
            autocomplete="email" required autofocus
            class="w-full p-2 border border-gray-300 rounded font-serif text-[#5c3202]
                   placeholder-[#C99F85] focus:outline-none focus:ring-2 focus:ring-[#C99F85]"
            placeholder="votre mail @mail.com"/>
        </div>

        <div>
          <label class="block text-xl text-[#5c3202] font-serif font-light mb-1">
            Mot de passe
          </label>
          <input type="password" name="password" id="password"
            autocomplete="current-password" required
            class="w-full p-2 border border-gray-300 rounded font-serif text-[#5c3202]
                   focus:outline-none focus:ring-2 focus:ring-[#C99F85]"/>
        </div>

        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

        <button type="submit"
          class="w-full bg-[#C99F85] text-white p-2 rounded font-serif text-xl
                 font-light hover:bg-[#b08870] transition-colors">
          Se connecter
        </button>

      </div>
    </form>

    <p class="text-base text-center text-[#5c3202] font-serif font-light">
      Pas de compte ?
      <a href="{{ path('app_register') }}" class="text-[#C99F85] hover:underline">Créer un compte</a>
    </p>

  </div>
</div>
</body>
{% endblock %}