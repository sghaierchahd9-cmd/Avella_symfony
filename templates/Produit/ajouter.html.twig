{% extends 'base.html.twig' %}

{% block title %}Avella - Ajouter un produit{% endblock %}

{% block body %}
    <header class="sticky top-0 isolate z-50 border-b border-black/10 bg-[#c99f85]/95 backdrop-blur-md">
        <div class="mx-auto flex w-full max-w-[1400px] items-center gap-2 px-3 py-3 sm:px-4">
            <div class="flex shrink-0 items-center gap-3">
                <span class="font-serif text-2xl text-[#4f3222]">Avella</span>
                <nav class="hidden items-center gap-1 md:flex">
                    <a href="/" class="rounded-full px-4 py-2 text-sm font-medium text-[#4f3222] hover:bg-white/30">Home</a>
                    <a href="{{ path('produit_index') }}" class="rounded-full px-4 py-2 text-sm font-medium text-[#4f3222] hover:bg-white/30">Explorer</a>
                    <a href="{{ path('seller_dashboard') }}" class="rounded-full px-4 py-2 text-sm font-medium text-[#4f3222] hover:bg-white/30">Dashboard</a>
                </nav>
            </div>
            <div class="ml-auto flex items-center gap-2">
                {% if app.user %}
                    <span class="text-sm text-[#4f3222]">{{ app.user.nom }}</span>
                    <a href="{{ path('app_logout') }}" class="rounded-full bg-[#755440] px-4 py-2 text-sm text-white hover:bg-[#4f3222]">Deconnexion</a>
                {% endif %}
            </div>
        </div>
    </header>

    <main class="min-h-screen bg-[#f4e5d9] px-6 py-10">
        <div class="mx-auto max-w-2xl">
            <div class="mb-8">
                <a href="{{ path('seller_dashboard') }}" class="text-sm font-semibold text-[#75502a] hover:text-[#382301]">
                    Retour au dashboard
                </a>
                <h1 class="mt-3 font-serif text-3xl text-[#5c3202]">Ajouter un produit</h1>
                <p class="mt-1 text-sm text-[#75502a]">Complete les informations du produit pour l'ajouter a ta boutique.</p>
            </div>

            <section class="rounded-2xl border border-[#ccab89] bg-white/70 p-6 shadow-xl">
                {{ form_start(form, {'attr': {'class': 'flex flex-col gap-5', 'enctype': 'multipart/form-data'}}) }}
                    {{ form_errors(form) }}

                    <div>
                        {{ form_label(form.nom, null, {'label_attr': {'class': 'text-xs uppercase tracking-widest text-[#75502a] font-semibold'}}) }}
                        {{ form_widget(form.nom, {'attr': {'class': 'mt-1 w-full rounded-xl border border-[#ccab89] bg-[#eddcce] px-3 py-2 text-[#382301] focus:outline-none focus:ring-2 focus:ring-[#c99f85]'}}) }}
                        {{ form_errors(form.nom) }}
                    </div>

                    <div>
                        {{ form_label(form.prix, null, {'label_attr': {'class': 'text-xs uppercase tracking-widest text-[#75502a] font-semibold'}}) }}
                        {{ form_widget(form.prix, {'attr': {'class': 'mt-1 w-full rounded-xl border border-[#ccab89] bg-[#eddcce] px-3 py-2 text-[#382301] focus:outline-none focus:ring-2 focus:ring-[#c99f85]'}}) }}
                        {{ form_errors(form.prix) }}
                    </div>

                    <div>
                        {{ form_label(form.categorie, null, {'label_attr': {'class': 'text-xs uppercase tracking-widest text-[#75502a] font-semibold'}}) }}
                        {{ form_widget(form.categorie, {'attr': {'class': 'mt-1 w-full rounded-xl border border-[#ccab89] bg-[#eddcce] px-3 py-2 text-[#382301] focus:outline-none focus:ring-2 focus:ring-[#c99f85]'}}) }}
                        {{ form_errors(form.categorie) }}
                    </div>

                    <div>
                        {{ form_label(form.description, null, {'label_attr': {'class': 'text-xs uppercase tracking-widest text-[#75502a] font-semibold'}}) }}
                        {{ form_widget(form.description, {'attr': {'class': 'mt-1 min-h-32 w-full rounded-xl border border-[#ccab89] bg-[#eddcce] px-3 py-2 text-[#382301] focus:outline-none focus:ring-2 focus:ring-[#c99f85]'}}) }}
                        {{ form_errors(form.description) }}
                    </div>

                    <div>
                        {{ form_label(form.imageFile, null, {'label_attr': {'class': 'text-xs uppercase tracking-widest text-[#75502a] font-semibold'}}) }}
                        {{ form_widget(form.imageFile, {'attr': {'class': 'mt-1 w-full rounded-xl border border-dashed border-[#ccab89] bg-[#eddcce] px-3 py-3 text-sm text-[#382301]'}}) }}
                        {{ form_errors(form.imageFile) }}
                    </div>

                    <div class="flex justify-end gap-3 border-t border-[#ccab89] pt-5">
                        <a href="{{ path('seller_dashboard') }}" class="rounded-xl bg-white/70 px-4 py-2 text-sm font-semibold text-[#75502a] hover:bg-white">
                            Annuler
                        </a>
                        <button type="submit" class="rounded-xl bg-[#ccab89] px-5 py-2 text-sm font-bold text-[#382301] transition hover:bg-[#f3d38d]">
                            Enregistrer
                        </button>
                    </div>
                {{ form_end(form) }}
            </section>
        </div>
    </main>
{% endblock %}
