{# templates/buyer/dashboard.html.twig
   Buyer dashboard: hero slider + category carousel + tendances grid.
   Mirrors: pages/buyer/buyer-dashboard.php

   Expected variables:
     categories  (Categorie[])
     tendances   (Produit[])
     boutiques   (Boutique[])
     cartCount   (int)
#}
{% extends 'base.html.twig' %}

{% block title %}Accueil — Avella{% endblock %}

{% block body %}

    {# ── Navbar ── #}
    {{ include('components/_navbar.html.twig', { cartCount: cartCount }) }}

    {# ── Sidebar ── #}
    {{ include('components/_sidebar.html.twig', { categories: categories }) }}

    <main class="pt-16">

        {# ── Flash messages ── #}
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="max-w-7xl mx-auto px-6 pt-4">
                    <div class="rounded-xl px-4 py-3 text-sm font-medium
                    {{ type == 'success' ? 'bg-green-50 text-green-700 border border-green-200' : 'bg-red-50 text-red-700 border border-red-200' }}">
                        {{ message }}
                    </div>
                </div>
            {% endfor %}
        {% endfor %}

        {# ──────────────────────────────────────────────
       HERO SLIDER
       Mirrors the <div id="slider"> in buyer-dashboard.php
       Controlled by buyer-dashboard.js: nextSlidepub / prevSlidepub
    ────────────────────────────────────────────── #}
        <section class="relative overflow-hidden bg-indigo-50" style="height: 420px;">

            {# Slides — one per boutique that has a cover photo #}
            <div id="slider" class="flex h-full transition-transform duration-500">
                {% set slideCount = 0 %}
                {% for boutique in boutiques %}
                    {% if boutique.photoCouverture %}
                        {% set slideCount = slideCount + 1 %}
                        <div class="min-w-full h-full relative flex-shrink-0">
                            <img src="{{ asset('images/' ~ boutique.photoCouverture) }}"
                                 alt="{{ boutique.nom }}"
                                 class="w-full h-full object-cover">
                            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent
                            flex flex-col justify-end px-10 pb-10">
                                <h2 class="text-white text-3xl font-bold">{{ boutique.nom }}</h2>
                                {% if boutique.description %}
                                    <p class="text-white/80 mt-1 max-w-md text-sm">{{ boutique.description }}</p>
                                {% endif %}
                            </div>
                        </div>
                    {% endif %}
                {% endfor %}

                {# Fallback slide when no boutique has a cover photo #}
                {% if slideCount == 0 %}
                    <div class="min-w-full h-full flex items-center justify-center bg-indigo-100">
                        <div class="text-center space-y-3">
                            <h2 class="text-3xl font-bold text-indigo-700">Bienvenue sur Avella</h2>
                            <p class="text-indigo-500">Découvrez les meilleures boutiques locales.</p>
                            <a href="{{ path('produit_index') }}"
                               class="inline-block mt-2 px-6 py-2.5 bg-indigo-600 text-white rounded-xl text-sm font-semibold hover:bg-indigo-700 transition-colors">
                                Voir les produits
                            </a>
                        </div>
                    </div>
                {% endif %}
            </div>

            {# Slider controls #}
            {% if slideCount > 1 %}
                <button onclick="prevSlidepub()"
                        class="absolute left-4 top-1/2 -translate-y-1/2 bg-white/80 hover:bg-white
                       rounded-full p-2 shadow transition-colors z-10"
                        aria-label="Précédent">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-700" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                    </svg>
                </button>
                <button onclick="nextSlidepub()"
                        class="absolute right-4 top-1/2 -translate-y-1/2 bg-white/80 hover:bg-white
                       rounded-full p-2 shadow transition-colors z-10"
                        aria-label="Suivant">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-700" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                </button>
            {% endif %}

        </section>

        {# ──────────────────────────────────────────────
       CATEGORY CAROUSEL
       Mirrors the #categories-wrapper carousel in buyer-dashboard.php.
       Controlled by buyer-dashboard.js: nextSlide / prevSlide
    ────────────────────────────────────────────── #}
        <section class="max-w-7xl mx-auto px-6 mt-12">
            <div class="flex items-center justify-between mb-6">
                <h2 class="text-xl font-bold text-gray-800">Catégories</h2>
                <div class="flex gap-2">
                    <button onclick="prevSlide()"
                            class="p-2 border border-gray-200 rounded-lg hover:bg-gray-50 transition-colors"
                            aria-label="Catégorie précédente">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-gray-600" fill="none"
                             viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                        </svg>
                    </button>
                    <button onclick="nextSlide()"
                            class="p-2 border border-gray-200 rounded-lg hover:bg-gray-50 transition-colors"
                            aria-label="Catégorie suivante">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-gray-600" fill="none"
                             viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                        </svg>
                    </button>
                </div>
            </div>

            {# Carousel viewport — overflow hidden; inner strip slides with transform #}
            <div class="overflow-hidden">
                <div id="categories-wrapper"
                     class="flex gap-4 transition-transform duration-300"
                     style="width: max-content;">
                    {% for categorie in categories %}
                        {# Each card: fixed 252px wide (CARD_W = 276 with gap = 276px step in JS) #}
                        <a href="{{ path('produit_index', { categorie: categorie.nom }) }}"
                           class="flex-shrink-0 w-[252px] rounded-2xl overflow-hidden bg-white border border-gray-100
                          shadow-sm hover:shadow-md transition-shadow group">
                            <div class="h-36 bg-gray-100 overflow-hidden">
                                {% if categorie.photo %}
                                    <img src="{{ asset('images/' ~ categorie.photo) }}"
                                         alt="{{ categorie.nom }}"
                                         class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300">
                                {% else %}
                                    <div class="w-full h-full flex items-center justify-center text-4xl text-gray-300">🏷️</div>
                                {% endif %}
                            </div>
                            <div class="px-4 py-3">
                                <p class="text-sm font-semibold text-gray-800 truncate">{{ categorie.nom }}</p>
                            </div>
                        </a>
                    {% else %}
                        <p class="text-sm text-gray-400">Aucune catégorie disponible.</p>
                    {% endfor %}
                </div>
            </div>
        </section>

        {# ──────────────────────────────────────────────
       TENDANCES (latest products)
       Mirrors the "tendances" product grid in buyer-dashboard.php
    ────────────────────────────────────────────── #}
        <section class="max-w-7xl mx-auto px-6 mt-14 mb-16">
            <h2 class="text-xl font-bold text-gray-800 mb-6">Tendances</h2>

            {% if tendances|length > 0 %}
                <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-5">
                    {% for produit in tendances %}
                        <a href="{{ path('produit_show', { id: produit.id }) }}"
                           class="bg-white rounded-2xl border border-gray-100 shadow-sm
                      hover:shadow-md transition-shadow overflow-hidden group">
                            <div class="h-44 bg-gray-100 overflow-hidden">
                                {% if produit.image %}
                                    <img src="{{ asset('images/' ~ produit.image) }}"
                                         alt="{{ produit.nom }}"
                                         class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300">
                                {% else %}
                                    <div class="w-full h-full flex items-center justify-center text-5xl text-gray-200">📦</div>
                                {% endif %}
                            </div>
                            <div class="px-4 py-3">
                                <p class="text-sm font-semibold text-gray-800 truncate">{{ produit.nom }}</p>
                                <p class="text-xs text-gray-400 truncate mt-0.5">
                                    {{ produit.boutique ? produit.boutique.nom : '' }}
                                </p>
                                <p class="text-indigo-600 font-bold text-sm mt-1">
                                    {{ produit.prix|number_format(2, ',', ' ') }} DT
                                </p>
                            </div>
                            {# Quick-add button — handled by cart.js via data-produit-id #}
                            <div class="px-4 pb-3">
                                <button class="add-to-cart-btn w-full py-2 bg-indigo-600 text-white text-xs font-semibold
                                   rounded-xl hover:bg-indigo-700 transition-colors"
                                        data-produit-id="{{ produit.id }}"
                                        onclick="event.preventDefault(); event.stopPropagation();">
                                    Ajouter au panier
                                </button>
                            </div>
                        </a>
                    {% endfor %}
                </div>
            {% else %}
                <p class="text-sm text-gray-400">Aucun produit disponible pour le moment.</p>
            {% endif %}
        </section>

    </main>

    {# ── Footer ── #}
    {{ include('components/_footer.html.twig') }}

    {# ── Cart modal (includes AVELLA_ROUTES injection) ── #}
    {{ include('components/_cart_modal.html.twig', { cartCount: cartCount }) }}

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/buyer-dashboard.js') }}"></script>
    <script src="{{ asset('js/cart.js') }}"></script>
{% endblock %}
