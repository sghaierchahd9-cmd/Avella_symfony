            </svg>
        </a>
        {# WhatsApp #}
        <a href="#" class="text-[#4f3222] hover:text-[#2f1d13] transition p-1">
            <svg fill="currentColor" width="30" height="30" viewBox="0 0 24 24">
                <path fill-rule="evenodd" clip-rule="evenodd" d="M3.50002 12C3.50002 7.30558 7.3056 3.5 12 3.5C16.6944 3.5 20.5 7.30558 20.5 12C20.5 16.6944 16.6944 20.5 12 20.5C10.3278 20.5 8.77127 20.0182 7.45798 19.1861C7.21357 19.0313 6.91408 18.9899 6.63684 19.0726L3.75769 19.9319L4.84173 17.3953C4.96986 17.0955 4.94379 16.7521 4.77187 16.4751C3.9657 15.176 3.50002 13.6439 3.50002 12ZM12 1.5C6.20103 1.5 1.50002 6.20101 1.50002 12C1.50002 13.8381 1.97316 15.5683 2.80465 17.0727L1.08047 21.107C0.928048 21.4637 0.99561 21.8763 1.25382 22.1657C1.51203 22.4552 1.91432 22.5692 2.28599 22.4582L6.78541 21.1155C8.32245 21.9965 10.1037 22.5 12 22.5C17.799 22.5 22.5 17.799 22.5 12C22.5 6.20101 17.799 1.5 12 1.5Z"/>
            </svg>
        </a>
    </div>

    <div class="flex items-center justify-between px-10 pb-5 pt-3 flex-wrap gap-3 border-t border-[#b5896e]/40 mt-2">
        <p class="text-sm text-[#372608]">
            <a href="#" class="hover:text-[#7f5641] hover:underline">Conditions d'utilisation</a> |
            <a href="#" class="hover:text-[#7f5641] hover:underline"> Politique de confidentialité</a> |
            <a href="#" class="hover:text-[#7f5641] hover:underline"> Politique de retour</a> |
            <a href="#" class="hover:text-[#7f5641] hover:underline"> FAQ</a>
        </p>
        <p class="text-sm text-[#41392c]">&copy; {{ "now"|date("Y") }} Avella. Tous droits réservés.</p>
    </div>
</footer>

{# ============================================================ CART MODAL (utilisateurs connectés) #}
{% if app.user %}
    <div id="cart-modal" class="pointer-events-none fixed inset-0 z-[60] opacity-0 transition-opacity duration-300">
        <div id="cart-overlay" class="absolute inset-0 bg-black/45"></div>
        <aside id="cart-panel"
               class="absolute right-0 top-0 flex h-full w-[22rem] max-w-[92vw] translate-x-full flex-col
                  overflow-y-auto border-l border-[#a88066] bg-[#f9f0e8]
                  shadow-[-18px_0_46px_rgba(77,48,31,0.28)] transition-transform duration-300 ease-out">
            <div class="flex items-center justify-between border-b border-[#c9a989] px-6 py-4">
                <h2 class="font-serif text-xl font-bold text-[#4f3222]">Mon Panier</h2>
                <button id="cart-close-btn" class="rounded-full p-2 text-[#5b3d2a] hover:bg-white/50 transition">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="h-6 w-6">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/>
                    </svg>
                </button>
            </div>
            <div id="cart-content" class="flex-1 overflow-y-auto px-4 py-4">
                <p class="text-center text-[#8a6652] font-serif py-8">Chargement…</p>
            </div>
            <div class="border-t border-[#c9a989] px-6 py-4">
                <div class="flex justify-between mb-3">
                    <span class="font-semibold text-[#4f3222]">Total :</span>
                    <span id="cart-total" class="font-bold text-[#755440]">0.000 TND</span>
                </div>
                <form action="{{ path('cart_confirmer') }}" method="POST">
                    <input type="hidden" name="_token" value="{{ csrf_token('confirm_order') }}">
                    <button type="submit" class="w-full bg-[#755440] text-white font-bold py-3 rounded-2xl hover:bg-[#4f3222] transition">
                        Confirmer la commande
                    </button>
                </form>
            </div>
        </aside>
    </div>
