{% extends 'base.html.twig' %}

{% block title %}Avella{% endblock %}

{% block body %}
<head title="Avella">
<script>
    tailwind.config = {
        theme: {
            extend: {
                colors: {
                    avella1: '#f4e5d9',
                    avella2: '#e9d3c3',
                    avella3: '#c99f85',
                    avella4: '#8b674f',
                    avella5: '#4f3222',
                    avella6: '#2f1d13',
                },
                fontFamily: {
                    serif: ['"Playfair Display"', 'Georgia', 'serif'],
                }
            }
        }
    }
</script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="stylesheet" href="{{ asset('build/tailwind.css') }}">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700;900&display=swap" rel="stylesheet">
<style>
    body { font-family: 'Playfair Display', Georgia, serif; }
    .btn-primary {
        background-color: #c99f85;
        color: #4f3222;
        padding: 0.45rem 1.1rem;
        border-radius: 9999px;
        font-weight: 600;
        font-size: 0.875rem;
        transition: background-color 0.2s;
    }
    .btn-primary:hover { background-color: #b08a72; }
</style>
</head>
<body class="overflow-y-scroll overflow-x-hidden scroll-smooth bg-[#f4e5d9] min-h-screen">

{# ============================================================ NAVBAR #}
<header class="sticky top-0 isolate z-50 border-b border-black/10 bg-[#c99f85]/95 backdrop-blur-md">
    <div class="mx-auto flex w-full max-w-[1400px] items-center gap-2 px-3 py-3 sm:px-4">

        {# Burger #}
        <button id="open-sidebar" aria-label="Open sidebar"
                class="rounded-full p-2 text-[#4f3222] transition hover:bg-[#755440] hover:text-[#fff8f3] hover:shadow-[0_10px_20px_rgba(139,103,79,0.35)] active:scale-95">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/>
            </svg>
        </button>

        {# Logo + nav links #}
        <div class="flex shrink-0 items-center gap-3">
            <img src="{{ asset('images/AHHH.png') }}" alt="Avella" class="h-10 sm:h-11">
            <div class="hidden items-center gap-1 md:flex">
                <a href="{{ path('app_home') }}" class="rounded-full px-4 py-2 text-sm font-medium tracking-wide text-avella5 transition hover:bg-white/30 hover:text-avella6">Home</a>
                <a href="{{ path('produit_index') }}" class="rounded-full px-4 py-2 text-sm font-medium tracking-wide text-avella5 transition hover:bg-white/30 hover:text-avella6">Explore</a>
                <a href="{{ path('app_boutique') }}" class="rounded-full px-4 py-2 text-sm font-medium tracking-wide text-avella5 transition hover:bg-white/30 hover:text-avella6">Boutiques</a>
                {% if app.user and 'ROLE_VENDEUR' in app.user.roles %}
                    <a href="{{ path('seller_dashboard') }}" class="rounded-full px-4 py-2 text-sm font-medium tracking-wide text-avella5 transition hover:bg-white/30 hover:text-avella6">Mon Dashboard</a>
                {% endif %}
            </div>
        </div>

        {# Search bar #}
        <div class="relative mx-auto hidden max-w-xl flex-1 md:flex">
            <form action="{{ path('produit_index') }}" method="GET" class="relative w-full flex">
                <span class="absolute inset-y-0 left-3 flex items-center text-[#5D4133]">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35m0 0A7.5 7.5 0 1110.5 3a7.5 7.5 0 016.15 13.65z"/>
                    </svg>
                </span>
                <input type="text" name="nom" placeholder="Rechercher..."
                       class="w-full rounded-full border border-[#7f5e49] bg-[#e3d5cc] px-10 py-2 font-light placeholder-[#5D4133] transition focus:border-avella3 focus:outline-none focus:ring-2 focus:ring-avella3">
            </form>
        </div>

        {# Cart + account #}
        <div class="ml-auto flex items-center gap-1.5 sm:gap-2">
            <button id="cart-open-btn" aria-label="Panier"
                    class="relative rounded-full p-1.5 text-xl transition hover:bg-white/30">
                <svg xmlns="http://www.w3.org/2000/svg" width="35" height="35" viewBox="0 0 21 21">
                    <g fill="none" fill-rule="evenodd" transform="translate(2 4)">
                        <path d="m3 2.5h12.5l-1.5855549 5.54944226c-.2453152.85860311-1.0300872 1.45055774-1.9230479 1.45055774h-6.70131161c-1.01909844 0-1.87522688-.76627159-1.98776747-1.77913695l-.80231812-7.22086305h-2"
                              stroke="#000000" stroke-linecap="round" stroke-linejoin="round"/>
                        <g fill="#000000"><circle cx="5" cy="12" r="1"/><circle cx="13" cy="12" r="1"/></g>
                    </g>
                </svg>
                {% if app.user %}
                    <span id="navbar-cart-count"
                          class="absolute -top-1 -right-1 bg-[#755440] text-white text-[10px] font-bold rounded-full w-4 h-4 flex items-center justify-center {{ cartCount > 0 ? '' : 'hidden' }}">
                        {{ cartCount }}
                    </span>
                {% endif %}
            </button>

            {% if app.user %}
                <a href="{{ '#' }}" class="btn-primary ml-1 text-sm font-medium text-[#4f3222] hover:underline">Mon compte</a>
                <a href="{{ path('app_logout') }}" class="btn-primary ml-1 text-sm font-medium text-[#4f3222] hover:underline">Déconnexion</a>
            {% else %}
                <a href="{{ path('app_login') }}" class="btn-primary ml-1">Login</a>
            {% endif %}
        </div>
    </div>
</header>
<br>
{# ============================================================ HERO SLIDER #}
<section class="relative w-full overflow-hidden mt-6">
    <div id="slider" class="flex transition-transform duration-500 bg-[#C99F85] ease-in-out">
        <img src="{{ asset('images/photo1.png') }}" class="w-full flex-shrink-0 object-cover h-[500px]" alt="">
        <img src="{{ asset('images/photo2.png') }}" class="w-full flex-shrink-0 object-cover h-[500px]" alt="">
        <img src="{{ asset('images/photo3.png') }}" class="w-full flex-shrink-0 object-cover h-[500px]" alt="">
    </div>
    <button onclick="prevSlidepub()" class="absolute left-4 top-1/2 -translate-y-1/2 bg-white/70 hover:bg-white p-3 rounded-full shadow text-[#4f3222] font-bold">❮</button>
    <button onclick="nextSlidepub()" class="absolute right-4 top-1/2 -translate-y-1/2 bg-white/70 hover:bg-white p-3 rounded-full shadow text-[#4f3222] font-bold">❯</button>
    {# Dots #}
    <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2">
        <span class="slider-dot w-2.5 h-2.5 rounded-full bg-white/80 cursor-pointer" onclick="goToSlide(0)"></span>
        <span class="slider-dot w-2.5 h-2.5 rounded-full bg-white/40 cursor-pointer" onclick="goToSlide(1)"></span>
        <span class="slider-dot w-2.5 h-2.5 rounded-full bg-white/40 cursor-pointer" onclick="goToSlide(2)"></span>
    </div>
</section>

{# ============================================================ CATEGORIES #}
<section class="mt-16 px-4">
    <h2 class="text-4xl text-[#6c550f] font-bold font-serif ml-8 mb-8">Nos Catégories</h2>

    {% if categories is not empty %}
        <div class="relative overflow-hidden">
            <div id="categories-wrapper" class="flex transition-transform duration-500 ease-in-out">
                {% for cat in categories %}
                    <div class="min-w-[260px] mx-2 flex-shrink-0">
                        <a href="{{ path('app_boutique') }}?categorie_id={{ cat.id }}"
                           class="relative block rounded-2xl shadow-xl overflow-hidden hover:scale-95 transition-transform duration-300">
                            {% if cat.photo %}
                                <img src="{{ asset(cat.photo) }}"
                                     alt="{{ cat.nom }}"
                                     class="h-96 w-64 object-cover"
                                     onerror="this.parentNode.style.background='#c9a989'">
                            {% else %}
                                <div class="h-96 w-64 bg-[#c9a989] flex items-center justify-center">
                                    <span class="font-serif text-2xl text-[#4f3222]">{{ cat.nom }}</span>
                                </div>
                            {% endif %}
                            <span class="absolute bottom-2 left-2 text-white font-bold font-serif text-xl drop-shadow-lg">
                                {{ cat.nom }}
                            </span>
                        </a>
                    </div>
                {% endfor %}
            </div>

            <button onclick="prevSlide()" class="absolute left-2 top-1/2 -translate-y-1/2 bg-white/70 hover:bg-white p-3 rounded-full shadow z-10 text-[#4f3222] font-bold">❮</button>
            <button onclick="nextSlide()" class="absolute right-2 top-1/2 -translate-y-1/2 bg-white/70 hover:bg-white p-3 rounded-full shadow z-10 text-[#4f3222] font-bold">❯</button>
        </div>
    {% else %}
        <p class="ml-8 text-[#8a6652] font-serif">Aucune catégorie disponible.</p>
    {% endif %}
</section>

{# ============================================================ TENDANCES #}
<section class="mt-20 px-4 pb-16">
    <h2 class="text-4xl text-[#6c550f] font-bold font-serif ml-8 mb-8">Tendances Actuelles</h2>

    {% if tendances is not empty %}
        <div class="flex flex-wrap gap-6 ml-8">
            {% for prod in tendances %}
                <div class="bg-white rounded-2xl shadow-md overflow-hidden w-64 flex flex-col hover:shadow-xl transition-shadow">
                    <a href="{{ path('produit_show', {id: prod.id}) }}">
                        {% if prod.image %}
                            <img src="{{ asset(prod.image) }}"
                                 alt="{{ prod.nom }}"
                                 class="h-64 w-full object-cover"
                                 onerror="this.src='{{ asset('images/prodvend2.png') }}'">
                        {% else %}
                            <div class="h-64 w-full bg-[#ecdfd5] flex items-center justify-center">
                                <span class="font-serif text-4xl text-[#755440]">{{ prod.nom|slice(0,1) }}</span>
                            </div>
                        {% endif %}
                    </a>
                    <div class="p-4 flex flex-col gap-1 flex-1">
                        <span class="text-xs font-semibold uppercase tracking-widest text-[#c99f85]">
                            {% if prod.boutique %}{{ prod.boutique.nom }}{% endif %}
                            {% if prod.categorie %} · {{ prod.categorie.nom }}{% endif %}
                        </span>
                        <a href="{{ path('produit_show', {id: prod.id}) }}"
                           class="font-serif font-bold text-[#3e2612] text-base hover:underline">
                            {{ prod.nom }}
                        </a>
                        <p class="text-[#755440] font-bold text-sm">
                            {{ prod.prix|number_format(2, '.', ' ') }} TND
                        </p>

                        {% if app.user %}
                            <button class="avella-add-to-cart mt-2 w-full bg-[#ccab89] hover:bg-[#f3d38d] hover:border-2 hover:border-[#382301]
                                   text-[#4c3e14] font-serif font-bold rounded-2xl py-2 text-sm transition"
                                    data-produit-id="{{ prod.id }}">
                                Ajouter au panier
                            </button>
                        {% else %}
                            <a href="{{ path('app_login') }}"
                               class="mt-2 block text-center bg-[#ccab89] hover:bg-[#c99f85] text-[#382301]
                              font-serif font-bold rounded-2xl py-2 text-sm transition">
                                🔒 Connectez-vous
                            </a>
                        {% endif %}
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <p class="ml-8 text-[#8a6652] font-serif">Aucun produit tendance pour le moment.</p>
    {% endif %}
</section>

{# ============================================================ FOOTER #}
<footer class="mt-20 bg-[#c99f85]">
    <div class="ml-10 py-8 pr-10">
        <p class="font-serif text-8xl font-bold text-[#ebd5c5]">AVELLA</p>
        <p class="text-2xl mt-6 font-semibold text-[#4f3222]">Qui sommes nous ?</p>
        <p class="text-base mt-3 text-[#422c22] max-w-3xl leading-relaxed tracking-wide">
            ⥼ Avella est une plateforme dédiée aux small businesses, leur permettant de vendre leurs produits en
            ligne en toute simplicité.
            Notre site web offre une visibilité optimale aux entreprises locales et met en valeur des produits de
            haute qualité.
            De plus, nous facilitons la livraison à domicile afin de garantir une expérience client pratique et fiable.
        </p>
    </div>

    <div class="flex items-center gap-3 px-10 pb-2">
        {# Facebook #}
        <a href="#" class="text-[#4f3222] hover:text-[#2f1d13] transition p-1">
            <svg fill="currentColor" width="30" height="30" viewBox="0 0 24 24">
